# Copy to keystore.properties (gitignored) and fill in values.
# Generate a keystore once and back it up safely — you need the same key for all updates.
#
#   keytool -genkeypair -v \
#     -keystore /secure/path/esochan-release.jks \
#     -alias esochan \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass '…' -keypass '…' \
#     -dname "CN=esochan, OU=Mobile, O=esochan, C=US"
#
# PKCS12 keystores use the same password for store and key.

storeFile=/absolute/path/to/esochan-release.jks
storePassword=change-me
keyAlias=esochan
keyPassword=change-me
