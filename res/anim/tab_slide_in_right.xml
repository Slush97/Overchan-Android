<?xml version="1.0" encoding="utf-8"?>
<!--
    Forward navigation (opening a board / thread): the incoming screen enters
    from the right edge and slides left into place, reinforcing the spatial
    model of moving "deeper" across 4chan's horizontal shelf of boards.
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="300"
    android:fromXDelta="100%p"
    android:toXDelta="0"
    android:interpolator="@android:interpolator/fast_out_slow_in" />
