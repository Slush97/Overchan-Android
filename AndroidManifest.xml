<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="auto"
    tools:ignore="UnusedAttribute"
    android:versionCode="55"
    android:versionName="1.5.1">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <application
        android:name="nya.miku.wishmaster.common.MainApplication"
        android:allowBackup="true"
        android:supportsRtl="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:preserveLegacyExternalStorage="true" >
        
        <activity
            android:name="nya.miku.wishmaster.ui.MainActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:launchMode="singleTask"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
                <!-- domains -->
                <data android:host="iichan.hk" />
                <data android:host="www.iichan.hk" />
                <data android:host="hatsune.ru" />
                <data android:host="nowere.net" />
                <data android:host="www.nowere.net" />
                <data android:host="owlchan.ru" />
                <data android:host="www.owlchan.ru" />
                
                <data android:host="horochan.ru" />
                
                <data android:host="allchan.su" />
                <data android:host="www.allchan.su" />
                
                <data android:host="420chan.org" />
                <data android:host="boards.420chan.org" />
                
                <data android:host="2-chru.net" />
                <data android:host="2chru.net" />
                <data android:host="dmirrgetyojz735v.onion" />
                <data android:host="www.2-chru.net" />
                <data android:host="www.2chru.net" />
                <data android:host="www.dmirrgetyojz735v.onion" />
                
                <data android:host="uchan.to" />
                <data android:host="uchan.org.ua" />
                
                <data android:host="sich.co.ua" />
                
                <data android:host="syn-ch.com" />
                <data android:host="syn-ch.org" />
                <data android:host="syn-ch.ru" />
                <data android:host="syn-ch.com.ua" />
                
                <data android:host="inach.org" />
                <data android:host="www.inach.org" />
                
                <data android:host="claire.ws" />
                <data android:host="www.claire.ws" />
                
                <data android:host="kurisa.ch" />
                <data android:host="www.kurisa.ch" />
                
                <data android:host="10ch.ru" />
                <data android:host="www.10ch.ru" />
                
                <data android:host="haruhichan.ru" />
                
                <data android:host="chuck.dfwk.ru" />
                
                <data android:host="4chan.org" />
                <data android:host="www.4chan.org" />
                <data android:host="boards.4chan.org" />
                
                <data android:host="pl.vichan.net" />
                
                <data android:host="samachan.org" />
                <data android:host="www.samachan.org" />

                <data android:host="lainchan.org" />
                <data android:host="www.lainchan.org" />
                
                <data android:host="dva-ch.net" />
                
                <data android:host="02ch.su" />
                
                <data android:host="tohno-chan.com" />
                <data android:host="www.tohno-chan.com" />
                
                <data android:host="anon.fm" />
                
                <data android:host="2ch.hk" />
                <data android:host="www.2ch.hk" />
                <data android:host="2ch.pm" />
                <data android:host="2-ch.so" />
                <data android:host="2ch.re" />
                <data android:host="2ch.tf" />
                <data android:host="2ch.wf" />
                <data android:host="2ch.yt" />
                
                <data android:host="arhivach.org" />
                <data android:host="www.arhivach.org" />
                <!-- end of domains -->
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="text/html" />              
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:host="*" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.mhtml" />
                <data android:pathPattern=".*\\..*\\.mhtml" />
                <data android:pathPattern=".*\\..*\\..*\\.mhtml" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.mhtml" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\..*\\.mhtml" />
            </intent-filter>
        </activity>
        
        <activity
            android:name="nya.miku.wishmaster.ui.posting.PostFormActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:exported="false" />
        
        <activity
            android:name="nya.miku.wishmaster.ui.gallery.GalleryActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:theme="@style/Transparent"
            android:process=":Gallery"
            android:exported="false" />
        
        <activity
            android:name="nya.miku.wishmaster.ui.gallery.GalleryInteractiveExceptionHandler"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:theme="@style/Transparent"
            android:exported="false" />
        
        <activity
            android:name="nya.miku.wishmaster.ui.posting.PostingProgressActivity"
            android:theme="@style/Theme_Dialog_Switch"
            android:launchMode="singleTask"
            android:exported="false" />
        
        <activity
            android:name="nya.miku.wishmaster.ui.downloading.DownloadingProgressActivity"
            android:theme="@style/Theme_Dialog_Switch"
            android:launchMode="singleTask"
            android:exported="false" />
        
        <activity
            android:name="nya.miku.wishmaster.ui.downloading.DownloadingErrorReportActivity"
            android:theme="@style/Theme_Dialog_Switch"
            android:launchMode="singleTask"
            android:exported="false" />
        
        <activity android:name="nya.miku.wishmaster.lib.FileDialogActivity" android:exported="false" />
        <activity android:name="nya.miku.wishmaster.ui.settings.PreferencesActivity" android:exported="false" />
        <activity android:name="nya.miku.wishmaster.ui.settings.AutohideActivity" android:exported="false" />
        <activity android:name="nya.miku.wishmaster.ui.settings.ChansSortActivity" android:exported="false" />
        <activity android:name="nya.miku.wishmaster.ui.settings.CertificatesActivity" android:exported="false" />
        <activity android:name="nya.miku.wishmaster.ui.settings.CustomThemeListActivity" android:exported="false" />
        
        <activity android:name="nya.miku.wishmaster.ui.ShareActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>
        
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="dev.esoc.esochan.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
        
        <service android:name="nya.miku.wishmaster.ui.posting.PostingService" android:exported="false" />
        <service android:name="nya.miku.wishmaster.ui.downloading.DownloadingService" android:exported="false" android:foregroundServiceType="dataSync" />
        <service android:name="nya.miku.wishmaster.ui.tabs.TabsTrackerService" android:exported="false" android:foregroundServiceType="dataSync" />
        <service android:name="nya.miku.wishmaster.ui.gallery.GalleryBackend" android:exported="false" />
        
    </application>

</manifest>
